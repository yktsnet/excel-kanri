# Gemini API（自然言語検索機能で使用）
GEMINI_API_KEY=

# ファイル監視ディレクトリ（Samba共有フォルダのパス）
WATCH_DIR=

# SQLite データベースパス
DB_PATH=./kanri.db

# JWT 署名鍵（本番では openssl rand -hex 32 等で生成した値に差し替える）
JWT_SECRET=

# true の場合デモ用ログイン画面・シードデータを有効化
DEMO_MODE=false

# Gotenberg（xlsx → pdf 変換）のURL
GOTENBERG_URL=http://localhost:3000

# 書類種別マッピング YAML の配置ディレクトリ
MAPPING_DIR=examples/mansion/mapping

# 生成物（xlsx / pdf）の保存ディレクトリ
GENERATED_DIR=generated

# 共有フォルダ（ルートB。watchdog の監視対象ディレクトリ）
SHARED_DIR=shared
